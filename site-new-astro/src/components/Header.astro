---
import { buildWhatsAppLink, siteContent } from "../lib/site-content";

const logoPrincipal = siteContent.brandAssets?.logoUrl || "/assets/brand/logo-principal.svg";
const logoBlanco = "/assets/brand/logo-blanco.png";
const whatsappMessage = siteContent.siteConfig.header_whatsapp_mensaje?.trim() ||
  `Hola ${siteContent.businessName}, quiero hacer un pedido.`;
const whatsappHref = buildWhatsAppLink(siteContent.whatsapp, whatsappMessage);
---
<!-- TopAppBar -->
<header class="docked full-width top-0 sticky z-50 bg-surface/90 dark:bg-surface-dark/90 backdrop-blur-md shadow-[0_12px_32px_rgba(5,5,5,0.05)] h-20">
  <div class="max-w-7xl mx-auto px-6 h-20 flex justify-between items-center">
    <a class="inline-flex items-center hover:opacity-90 transition-opacity duration-200" href="index.html" aria-label={`Ir al inicio de ${siteContent.businessName}`}>
      <img class="h-12 w-auto block dark:hidden" src={logoPrincipal} alt={`Logo ${siteContent.businessName}`} loading="eager" decoding="async" fetchpriority="high" />
      <img class="h-12 w-auto hidden dark:block" src={logoBlanco} alt={`Logo ${siteContent.businessName} en blanco`} loading="eager" decoding="async" />
      <span class="sr-only">{siteContent.businessName}</span>
    </a>

    <nav class="hidden md:flex gap-8 items-center">
      <a class="text-[#595959] dark:text-gray-400 font-medium hover:text-[#7C563B] aria-[current=page]:text-[#7C563B] aria-[current=page]:font-bold font-headline text-lg hover:scale-105 transition-transform duration-300" href="catalogo.html">Catalogo</a>
      <a class="text-[#595959] dark:text-gray-400 font-medium hover:text-[#7C563B] aria-[current=page]:text-[#7C563B] aria-[current=page]:font-bold font-headline text-lg hover:scale-105 transition-transform duration-300" href="pasteles-personalizados.html">Personalizados</a>
      <a class="text-[#595959] dark:text-gray-400 font-medium hover:text-[#7C563B] aria-[current=page]:text-[#7C563B] aria-[current=page]:font-bold font-headline text-lg hover:scale-105 transition-transform duration-300" href="como-ordenar.html">Como ordenar</a>
      <a class="text-[#595959] dark:text-gray-400 font-medium hover:text-[#7C563B] aria-[current=page]:text-[#7C563B] aria-[current=page]:font-bold font-headline text-lg hover:scale-105 transition-transform duration-300" href="contacto-cobertura.html">Contacto</a>
    </nav>

    <a class="bg-primary-container text-on-primary-container px-6 py-2.5 rounded-full font-bold text-sm hover:scale-105 transition-transform duration-300 active:scale-95 hidden md:block" href={whatsappHref} target="_blank" rel="noopener noreferrer">
      Pedir por WhatsApp
    </a>

    <button class="md:hidden text-primary" type="button" aria-label="Abrir menu">
      <span class="material-symbols-outlined" style="font-size: 32px;">menu</span>
    </button>
  </div>
</header>
