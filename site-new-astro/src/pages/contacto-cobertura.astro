---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BottomNav from '../components/BottomNav.astro';
import '../styles/pages/contacto-cobertura.css';
---
<BaseLayout htmlClass="light" lang="es" bodyClass="bg-background text-on-surface">
  <Fragment slot="head">
    <!-- SEO Pack2 Start -->
    <meta name="description" content="Contacto y cobertura Hadi Cakes: zonas de entrega en Colima y canal directo por WhatsApp para pedidos y cotizaciones."/>
    <meta name="robots" content="index,follow"/>
    <link rel="canonical" href="https://hadicakes.local/contacto-cobertura.html"/>
    <link rel="icon" type="image/svg+xml" href="assets/favicon.svg"/>
    <meta property="og:title" content="Hadi Cakes"/>
    <meta property="og:description" content="Contacto y cobertura Hadi Cakes: zonas de entrega en Colima y canal directo por WhatsApp para pedidos y cotizaciones."/>
    <meta property="og:type" content="website"/>
    <meta property="og:site_name" content="Hadi Cakes"/>
    <meta property="og:locale" content="es_MX"/>
    <meta property="og:url" content="https://hadicakes.local/contacto-cobertura.html"/>
    <meta property="og:image" content="https://hadicakes.local/assets/images/img-019.jpg"/>
    <meta name="twitter:card" content="summary_large_image"/>
    <meta name="twitter:title" content="Hadi Cakes"/>
    <meta name="twitter:description" content="Contacto y cobertura Hadi Cakes: zonas de entrega en Colima y canal directo por WhatsApp para pedidos y cotizaciones."/>
    <meta name="twitter:image" content="https://hadicakes.local/assets/images/img-019.jpg"/>
    <!-- SEO Pack2 End -->
    <title>Contacto y Cobertura | Hadi Cakes</title>
    <script is:inline src="/assets/vendor/tailwindcss-cdn.js"></script>
    <link href="/assets/vendor/fonts-01.css" rel="stylesheet"/>
    <link href="/assets/vendor/fonts-04.css" rel="stylesheet"/>
    <link href="/assets/vendor/fonts-04.css" rel="stylesheet"/>
    <script is:inline id="tailwind-config">
          tailwind.config = {
            darkMode: "class",
            theme: {
              extend: {
                colors: {
                  "on-secondary-fixed": "#201a19",
                  "primary-fixed-dim": "#efbc9b",
                  "surface-container-high": "#e8e8e8",
                  "inverse-surface": "#2f3131",
                  "error-container": "#ffdad6",
                  "on-secondary": "#ffffff",
                  "secondary-container": "#e9ddda",
                  "inverse-primary": "#efbc9b",
                  "tertiary-container": "#a0c7d3",
                  "on-tertiary-fixed-variant": "#254c56",
                  "surface-bright": "#f9f9f9",
                  "secondary": "#655d5a",
                  "on-primary-fixed": "#2f1502",
                  "on-error-container": "#93000a",
                  "on-surface-variant": "#50443d",
                  "on-secondary-container": "#69615e",
                  "surface-container-lowest": "#ffffff",
                  "secondary-fixed-dim": "#cfc4c1",
                  "on-background": "#1a1c1c",
                  "primary": "#7c563b",
                  "inverse-on-surface": "#f1f1f1",
                  "primary-fixed": "#ffdcc6",
                  "surface-dim": "#dadada",
                  "surface-container-highest": "#e2e2e2",
                  "tertiary": "#3e646e",
                  "on-tertiary": "#ffffff",
                  "surface-container": "#eeeeee",
                  "on-tertiary-fixed": "#001f26",
                  "primary-container": "#e8b695",
                  "tertiary-fixed": "#c1e9f5",
                  "surface-variant": "#e2e2e2",
                  "on-error": "#ffffff",
                  "tertiary-fixed-dim": "#a6cdd9",
                  "surface-container-low": "#f3f3f3",
                  "on-primary-container": "#6a462c",
                  "surface-tint": "#7c563b",
                  "on-surface": "#1a1c1c",
                  "error": "#ba1a1a",
                  "on-primary": "#ffffff",
                  "on-primary-fixed-variant": "#623f25",
                  "secondary-fixed": "#ece0dd",
                  "on-secondary-fixed-variant": "#4d4543",
                  "background": "#f9f9f9",
                  "outline-variant": "#d4c3b9",
                  "outline": "#82746c",
                  "on-tertiary-container": "#2e545e",
                  "surface": "#f9f9f9"
                },
                fontFamily: {
                  "headline": ["Epilogue"],
                  "body": ["Plus Jakarta Sans"],
                  "label": ["Plus Jakarta Sans"]
                },
                borderRadius: {"DEFAULT": "1rem", "lg": "2rem", "xl": "3rem", "full": "9999px"},
              },
            },
          }
        </script>
  </Fragment>
  <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[999] focus:bg-primary focus:text-white focus:px-4 focus:py-2 focus:rounded-full">Saltar al contenido</a>
  <Header />
  <main id="main-content" class="max-w-7xl mx-auto px-6 py-12 md:py-20 space-y-20">
  <!-- Hero Section -->
  <section class="text-center space-y-4">
  <h1 class="text-4xl md:text-6xl font-black text-on-surface tracking-tight">Hablemos de tu próximo festejo</h1>
  <p class="text-secondary max-w-2xl mx-auto text-lg leading-relaxed">
                  Estamos listos para endulzar tus momentos especiales. Cuéntanos tu idea y nosotros la convertimos en un pastel artesanal único.
              </p>
  </section>
  <!-- Main Layout: Bento Style -->
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
  <!-- Contact Form Card -->
  <div class="lg:col-span-7 bg-surface-container-lowest p-8 md:p-12 rounded-xl shadow-[0_12px_32px_rgba(5,5,5,0.02)]">
  <h2 class="text-2xl font-bold text-primary mb-8">Envíanos un mensaje</h2>
  <form class="space-y-6" id="contact-whatsapp-form">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
  <div class="space-y-2">
  <label class="text-sm font-semibold text-secondary ml-1">Nombre</label>
  <input class="w-full bg-surface-container-high border-none rounded-xl p-4 focus:ring-2 focus:ring-primary transition-all placeholder:text-outline" placeholder="Tu nombre completo" type="text"/>
  </div>
  <div class="space-y-2">
  <label class="text-sm font-semibold text-secondary ml-1">WhatsApp</label>
  <input class="w-full bg-surface-container-high border-none rounded-xl p-4 focus:ring-2 focus:ring-primary transition-all placeholder:text-outline" placeholder="312 242 4208" type="tel"/>
  </div>
  </div>
  <div class="space-y-2">
  <label class="text-sm font-semibold text-secondary ml-1">Asunto</label>
  <input class="w-full bg-surface-container-high border-none rounded-xl p-4 focus:ring-2 focus:ring-primary transition-all placeholder:text-outline" placeholder="Ej: Cotización para Boda" type="text"/>
  </div>
  <div class="space-y-2">
  <label class="text-sm font-semibold text-secondary ml-1">Mensaje</label>
  <textarea class="w-full bg-surface-container-high border-none rounded-xl p-4 focus:ring-2 focus:ring-primary transition-all placeholder:text-outline" placeholder="¿Cómo te imaginas tu pastel ideal?" rows="4"></textarea>
  </div>
  <button class="w-full bg-primary text-on-primary py-4 rounded-full font-bold text-lg hover:scale-[1.02] active:scale-95 transition-all shadow-lg shadow-primary/20" type="submit">Enviar por WhatsApp</button>
  </form>
  </div>
  <!-- Info & Coverage Panel -->
  <div class="lg:col-span-5 flex flex-col gap-8">
  <!-- Coverage Card -->
  <div class="bg-surface-container-low p-8 rounded-xl overflow-hidden relative group">
  <h2 class="text-2xl font-bold text-on-surface mb-4">Zona de Cobertura</h2>
  <p class="text-secondary-container text-sm mb-6 bg-secondary px-3 py-1 rounded-full inline-block">Reparto en Colima y Villa de Álvarez</p>
  <ul class="space-y-4 mb-8">
  <li class="flex items-center gap-3 text-on-surface-variant font-medium">
  <span class="material-symbols-outlined text-primary" data-icon="location_on">location_on</span>
                              Colima Centro
                          </li>
  <li class="flex items-center gap-3 text-on-surface-variant font-medium">
  <span class="material-symbols-outlined text-primary" data-icon="location_on">location_on</span>
                              Villa de Álvarez
                          </li>
  <li class="flex items-center gap-3 text-on-surface-variant font-medium">
  <span class="material-symbols-outlined text-primary" data-icon="location_on">location_on</span>
                              Norte y Residenciales
                          </li>
  <li class="flex items-center gap-3 text-on-surface-variant font-medium">
  <span class="material-symbols-outlined text-primary" data-icon="location_on">location_on</span>
                              Sur y Aledaños
                          </li>
  <li class="flex items-center gap-3 text-on-surface-variant font-medium">
  <span class="material-symbols-outlined text-primary" data-icon="home_pin">home_pin</span>
                              Tekuan 56, Villas de Bugambilias, Villa de Alvarez
                          </li>
  </ul>
  <!-- Map Image Container -->
  <div class="aspect-video w-full rounded-lg overflow-hidden relative">
  <img alt="Mapa de Colima" class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700" data-alt="Modern minimalist map illustration of Colima city with soft pastel colors and highlighted delivery zones in warm tones" data-location="Colima, Mexico" src="assets/images/img-019.jpg" decoding="async" loading="eager" fetchpriority="high">
  <div class="absolute inset-0 bg-primary/10 pointer-events-none"></div>
  </div>
  </div>
  <!-- Social & Delivery Card -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
  <div class="bg-tertiary-fixed p-6 rounded-xl flex flex-col justify-between">
  <span class="material-symbols-outlined text-on-tertiary-container text-3xl" data-icon="delivery_dining">delivery_dining</span>
  <div>
  <h3 class="font-bold text-on-tertiary-container mt-4">Horarios de Entrega</h3>
  <p class="text-on-tertiary-fixed-variant text-sm">Lun - Sáb: 10am - 7pm</p>
  </div>
  </div>
  <div class="bg-secondary-fixed p-6 rounded-xl flex flex-col justify-between">
  <span class="material-symbols-outlined text-on-secondary-fixed text-3xl" data-icon="share">share</span>
  <div class="flex flex-wrap gap-4 mt-4">
  <a class="text-on-secondary-fixed hover:text-primary transition-colors" href="https://instagram.com/hadi.cakess" target="_blank" rel="noopener noreferrer">Instagram</a>
  <a class="text-on-secondary-fixed hover:text-primary transition-colors" href="https://facebook.com/HadiCakess" target="_blank" rel="noopener noreferrer">Facebook</a>
  <a class="text-on-secondary-fixed hover:text-primary transition-colors" href="https://wa.me/523122424208" target="_blank" rel="noopener noreferrer">WhatsApp</a>
  </div>
  </div>
  <div class="md:col-span-2 bg-surface-container-low p-4 rounded-xl border border-outline-variant/40">
  <img alt="Tarjeta oficial de Hadi Cakes" class="w-full h-auto rounded-lg object-cover" src="/assets/brand/tarjeta.jpg" loading="lazy" decoding="async">
  </div>
  </div>
  </div>
  </div>
  <!-- Overlapping Image Section (Artisanal Touch) -->
  <section class="relative h-96 rounded-xl overflow-hidden mt-20">
  <img alt="Taller de Hadi Cakes" class="w-full h-full object-cover" data-alt="Artisanal pastry chef hands decorating a bespoke minimalist cake with soft cream frosting in a sunlit modern kitchen atelier" src="assets/images/img-025.jpg" decoding="async" loading="lazy">
  <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent flex items-end p-8 md:p-16">
  <div class="text-white max-w-xl">
  <h2 class="text-3xl font-bold mb-2">Diseño y Sabor</h2>
  <p class="opacity-90">Cada pedido es una obra de arte creada especialmente para ti, utilizando solo ingredientes de la más alta calidad.</p>
  </div>
  </div>
  </section>
  </main>
  <Footer />
  <BottomNav />
  
  <script>
  (function () {
    const form = document.getElementById('contact-whatsapp-form');
    if (!form) return;
    form.addEventListener('submit', function (event) {
      event.preventDefault();
      const nombre = form.querySelector('input[placeholder="Tu nombre completo"]')?.value?.trim() || '';
      const whatsapp = form.querySelector('input[placeholder="312 242 4208"]')?.value?.trim() || '';
      const asunto = form.querySelector('input[placeholder="Ej: Cotización para Boda"]')?.value?.trim() || '';
      const mensaje = form.querySelector('textarea[placeholder="¿Cómo te imaginas tu pastel ideal?"]')?.value?.trim() || '';
  
      const lines = [
        'Hola Hadi Cakes, quiero enviar una solicitud:',
        nombre ? 'Nombre: ' + nombre : '',
        whatsapp ? 'WhatsApp: ' + whatsapp : '',
        asunto ? 'Asunto: ' + asunto : '',
        mensaje ? 'Mensaje: ' + mensaje : ''
      ].filter(Boolean);
  
      const text = encodeURIComponent(lines.join('\n'));
      window.open('https://wa.me/523122424208?text=' + text, '_blank', 'noopener,noreferrer');
    });
  })();
  </script>
</BaseLayout>
