---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BottomNav from '../components/BottomNav.astro';
import '../styles/pages/pasteles-personalizados.css';
---
<BaseLayout htmlClass="scroll-smooth" lang="es" bodyClass="bg-background text-on-surface font-body selection:bg-primary-container selection:text-on-primary-container">
  <Fragment slot="head">
    <!-- SEO Pack2 Start -->
    <meta name="description" content="Pasteles personalizados Hadi Cakes: cotiza tu diseno para boda, cumpleanos o evento especial con atencion en Colima."/>
    <meta name="robots" content="index,follow"/>
    <link rel="canonical" href="https://hadicakes.local/pasteles-personalizados.html"/>
    <link rel="icon" type="image/svg+xml" href="assets/favicon.svg"/>
    <meta property="og:title" content="Personalizados | Hadi Cakes"/>
    <meta property="og:description" content="Pasteles personalizados Hadi Cakes: cotiza tu diseno para boda, cumpleanos o evento especial con atencion en Colima."/>
    <meta property="og:type" content="website"/>
    <meta property="og:site_name" content="Hadi Cakes"/>
    <meta property="og:locale" content="es_MX"/>
    <meta property="og:url" content="https://hadicakes.local/pasteles-personalizados.html"/>
    <meta property="og:image" content="https://hadicakes.local/assets/images/img-017.jpg"/>
    <meta name="twitter:card" content="summary_large_image"/>
    <meta name="twitter:title" content="Personalizados | Hadi Cakes"/>
    <meta name="twitter:description" content="Pasteles personalizados Hadi Cakes: cotiza tu diseno para boda, cumpleanos o evento especial con atencion en Colima."/>
    <meta name="twitter:image" content="https://hadicakes.local/assets/images/img-017.jpg"/>
    <!-- SEO Pack2 End -->
    <title>Personalizados | Hadi Cakes</title>
    <script is:inline src="/assets/vendor/tailwindcss-cdn.js"></script>
    <link href="/assets/vendor/fonts-01.css" rel="stylesheet"/>
    <link href="/assets/vendor/fonts-04.css" rel="stylesheet"/>
    <link href="/assets/vendor/fonts-04.css" rel="stylesheet"/>
    <script is:inline id="tailwind-config">
          tailwind.config = {
            darkMode: "class",
            theme: {
              extend: {
                colors: {
                  "on-secondary-fixed": "#201a19",
                  "primary-fixed-dim": "#efbc9b",
                  "surface-container-high": "#e8e8e8",
                  "inverse-surface": "#2f3131",
                  "error-container": "#ffdad6",
                  "on-secondary": "#ffffff",
                  "secondary-container": "#e9ddda",
                  "inverse-primary": "#efbc9b",
                  "tertiary-container": "#a0c7d3",
                  "on-tertiary-fixed-variant": "#254c56",
                  "surface-bright": "#f9f9f9",
                  "secondary": "#655d5a",
                  "on-primary-fixed": "#2f1502",
                  "on-error-container": "#93000a",
                  "on-surface-variant": "#50443d",
                  "on-secondary-container": "#69615e",
                  "surface-container-lowest": "#ffffff",
                  "secondary-fixed-dim": "#cfc4c1",
                  "on-background": "#1a1c1c",
                  "primary": "#7c563b",
                  "inverse-on-surface": "#f1f1f1",
                  "primary-fixed": "#ffdcc6",
                  "surface-dim": "#dadada",
                  "surface-container-highest": "#e2e2e2",
                  "tertiary": "#3e646e",
                  "on-tertiary": "#ffffff",
                  "surface-container": "#eeeeee",
                  "on-tertiary-fixed": "#001f26",
                  "primary-container": "#e8b695",
                  "tertiary-fixed": "#c1e9f5",
                  "surface-variant": "#e2e2e2",
                  "on-error": "#ffffff",
                  "tertiary-fixed-dim": "#a6cdd9",
                  "surface-container-low": "#f3f3f3",
                  "on-primary-container": "#6a462c",
                  "surface-tint": "#7c563b",
                  "on-surface": "#1a1c1c",
                  "error": "#ba1a1a",
                  "on-primary": "#ffffff",
                  "on-primary-fixed-variant": "#623f25",
                  "secondary-fixed": "#ece0dd",
                  "on-secondary-fixed-variant": "#4d4543",
                  "background": "#f9f9f9",
                  "outline-variant": "#d4c3b9",
                  "outline": "#82746c",
                  "on-tertiary-container": "#2e545e",
                  "surface": "#f9f9f9"
                },
                fontFamily: {
                  "headline": ["Epilogue"],
                  "body": ["Plus Jakarta Sans"],
                  "label": ["Plus Jakarta Sans"]
                },
                borderRadius: {"DEFAULT": "1rem", "lg": "2rem", "xl": "3rem", "full": "9999px"},
              },
            },
          }
        </script>
  </Fragment>
  <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[999] focus:bg-primary focus:text-white focus:px-4 focus:py-2 focus:rounded-full">Saltar al contenido</a>
  <Header />
  <main id="main-content" class="min-h-screen">
  <!-- Hero Section -->
  <section class="relative pt-20 pb-32 overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 relative z-10">
  <div class="flex flex-col lg:flex-row items-center gap-16">
  <div class="lg:w-1/2">
  <span class="text-primary font-bold tracking-widest uppercase text-sm mb-4 block">Atelier Creativo</span>
  <h1 class="font-headline font-black text-6xl md:text-8xl text-on-surface leading-[1.1] mb-8">
                              Tus sueños <br/>
  <span class="text-primary-container text-outline">hechos pastel</span>
  </h1>
  <p class="text-body-lg text-secondary max-w-lg mb-12 leading-relaxed">
                              No solo horneamos; diseñamos piezas centrales comestibles que cuentan tu historia. Cada detalle es esculpido a mano con la precisión de un artista y el alma de un repostero.
                          </p>
  <a class="inline-flex items-center gap-4 bg-primary text-on-primary px-8 py-4 rounded-full font-bold text-lg hover:scale-105 transition-transform shadow-xl" href="#cotizacion">
                              Iniciar mi pedido
                              <span class="material-symbols-outlined">arrow_forward</span>
  </a>
  </div>
  <div class="lg:w-1/2 relative">
  <div class="relative w-full aspect-square rounded-xl overflow-hidden shadow-2xl rotate-3">
  <img alt="Modern artisanal wedding cake with abstract sugar art and pastel textures on a minimalist concrete background" class="w-full h-full object-cover" data-alt="Modern artisanal wedding cake with abstract sugar art and pastel textures on a minimalist concrete background" src="assets/images/img-017.jpg" decoding="async" loading="eager" fetchpriority="high">
  </div>
  <div class="absolute -bottom-10 -left-10 w-64 h-64 rounded-xl overflow-hidden border-8 border-background shadow-2xl -rotate-6 hidden md:block">
  <img alt="Close-up of delicate gold leaf details and hand-painted flowers on a sophisticated layered cake" class="w-full h-full object-cover" data-alt="Close-up of delicate gold leaf details and hand-painted flowers on a sophisticated layered cake" src="assets/images/img-014.jpg" decoding="async" loading="lazy">
  </div>
  </div>
  </div>
  </div>
  <!-- Decorative Background Element -->
  <div class="absolute top-0 right-0 -z-0 opacity-10 translate-x-1/2 -translate-y-1/4">
  <span class="material-symbols-outlined text-[40rem] text-primary-container" style="font-variation-settings: 'FILL' 1;">cake</span>
  </div>
  </section>
  <!-- Inspiration Gallery (Bento Style) -->
  <section class="py-24 bg-surface-container-low rounded-t-[3rem]">
  <div class="max-w-7xl mx-auto px-6">
  <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
  <div>
  <h2 class="font-headline font-bold text-4xl mb-4">Galería de Inspiración</h2>
  <p class="text-secondary max-w-md">Explora creaciones previas que desafiaron lo convencional. Tu idea es el próximo lienzo.</p>
  </div>
  <div class="flex gap-2">
  <button class="p-4 rounded-full bg-surface text-primary hover:bg-primary hover:text-on-primary transition-colors shadow-sm" type="button" aria-label="Anterior">
  <span class="material-symbols-outlined">chevron_left</span>
  </button>
  <button class="p-4 rounded-full bg-primary text-on-primary shadow-sm hover:scale-105 transition-transform" type="button" aria-label="Siguiente">
  <span class="material-symbols-outlined">chevron_right</span>
  </button>
  </div>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
  <div class="md:col-span-2 md:row-span-2 group relative overflow-hidden rounded-lg">
  <img alt="Large colorful children's birthday cake featuring whimsical hand-sculpted woodland creatures and forest elements" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" data-alt="Large colorful children's birthday cake featuring whimsical hand-sculpted woodland creatures and forest elements" src="assets/images/img-012.jpg" decoding="async" loading="lazy">
  <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-8">
  <p class="text-white font-bold text-xl">Bosque Mágico</p>
  </div>
  </div>
  <div class="group relative overflow-hidden rounded-lg h-64">
  <img alt="Minimalist geometric cake with sharp edges and metallic copper accents for a modern corporate event" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" data-alt="Minimalist geometric cake with sharp edges and metallic copper accents for a modern corporate event" src="assets/images/img-022.jpg" decoding="async" loading="lazy">
  </div>
  <div class="group relative overflow-hidden rounded-lg h-64">
  <img alt="Elegant monochromatic white cake with intricate lace-like frosting patterns and pearls" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" data-alt="Elegant monochromatic white cake with intricate lace-like frosting patterns and pearls" src="assets/images/img-008.jpg" decoding="async" loading="lazy">
  </div>
  <div class="md:col-span-2 group relative overflow-hidden rounded-lg h-80">
  <img alt="Vibrant tropical themed cake with edible hibiscus flowers and monstera leaf decorations" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" data-alt="Vibrant tropical themed cake with edible hibiscus flowers and monstera leaf decorations" src="assets/images/img-026.jpg" decoding="async" loading="lazy">
  </div>
  </div>
  </div>
  </section>
  <!-- Quotation Form -->
  <section class="py-32 bg-background" id="cotizacion">
  <div class="max-w-7xl mx-auto px-6">
  <div class="bg-surface-container-lowest rounded-xl shadow-[0_12px_32px_rgba(5,5,5,0.03)] overflow-hidden flex flex-col md:flex-row">
  <div class="md:w-1/3 bg-primary-container p-12 text-on-primary-container">
  <h3 class="font-headline font-black text-4xl mb-6">Empecemos a crear</h3>
  <p class="mb-8 font-medium opacity-90">Cuéntanos sobre tu evento. Procesamos cada solicitud de forma personalizada para asegurar que tu diseño sea único.</p>
  <ul class="space-y-6">
  <li class="flex items-center gap-4">
  <span class="material-symbols-outlined bg-white/20 p-2 rounded-full">palette</span>
  <span>Diseño 100% original</span>
  </li>
  <li class="flex items-center gap-4">
  <span class="material-symbols-outlined bg-white/20 p-2 rounded-full">schedule</span>
  <span>Respuesta en &lt; 24h</span>
  </li>
  <li class="flex items-center gap-4">
  <span class="material-symbols-outlined bg-white/20 p-2 rounded-full">verified</span>
  <span>Calidad artesanal premium</span>
  </li>
  </ul>
  </div>
  <div class="md:w-2/3 p-12">
  <form class="space-y-8">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
  <div class="space-y-2">
  <label class="font-bold text-sm text-secondary px-1">Nombre Completo</label>
  <input class="w-full bg-surface-container-high border-none rounded-lg p-4 focus:ring-2 focus:ring-primary transition-all" placeholder="¿Cómo te llamas?" type="text"/>
  </div>
  <div class="space-y-2">
  <label class="font-bold text-sm text-secondary px-1">Fecha del evento</label>
  <input class="w-full bg-surface-container-high border-none rounded-lg p-4 focus:ring-2 focus:ring-primary transition-all" type="date"/>
  </div>
  <div class="space-y-2">
  <label class="font-bold text-sm text-secondary px-1">Porciones (Aprox.)</label>
  <select class="w-full bg-surface-container-high border-none rounded-lg p-4 focus:ring-2 focus:ring-primary transition-all">
  <option>10 - 20 personas</option>
  <option>20 - 50 personas</option>
  <option>50 - 100 personas</option>
  <option>100+ personas</option>
  </select>
  </div>
  <div class="space-y-2">
  <label class="font-bold text-sm text-secondary px-1">Presupuesto Estimado (Opcional)</label>
  <input class="w-full bg-surface-container-high border-none rounded-lg p-4 focus:ring-2 focus:ring-primary transition-all" placeholder="Ej. $1,500 - $2,500" type="text"/>
  </div>
  </div>
  <div class="space-y-2">
  <label class="font-bold text-sm text-secondary px-1">Tema o Idea Central</label>
  <textarea class="w-full bg-surface-container-high border-none rounded-lg p-4 focus:ring-2 focus:ring-primary transition-all" placeholder="Descríbenos tu visión, colores favoritos o el motivo del festejo..." rows="4"></textarea>
  </div>
  <a class="w-full bg-primary text-on-primary py-5 rounded-full font-black text-xl flex items-center justify-center gap-3 hover:scale-[1.02] active:scale-95 transition-all shadow-lg" href="https://wa.me/523120000000?text=Hola%20Hadi%20Cakes%2C%20quiero%20cotizar%20un%20pastel%20personalizado." target="_blank" rel="noopener noreferrer">
  <span class="material-symbols-outlined">chat</span>
                                  Enviar cotización por WhatsApp
                              </a>
  </form>
  </div>
  </div>
  </div>
  </section>
  </main>
  <Footer />
  <BottomNav />
</BaseLayout>
