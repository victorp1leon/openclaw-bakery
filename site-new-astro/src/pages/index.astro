---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import BottomNav from "../components/BottomNav.astro";
import {
  baseUrlFromConfig,
  buildWhatsAppLink,
  formatPriceMxn,
  siteContent
} from "../lib/site-content";
import "../styles/pages/index.css";

const baseUrl = baseUrlFromConfig();
const seoTitle = siteContent.siteConfig.seo_titulo_inicio?.trim() || `${siteContent.businessName} • Reposteria Creativa Colima`;
const seoDescription =
  siteContent.siteConfig.seo_descripcion_inicio?.trim() ||
  `${siteContent.businessName} en Colima: reposteria creativa artesanal, pasteles por pedido y disenos personalizados.`;
const canonicalUrl = `${baseUrl}/index.html`;
const ogImagePath = siteContent.heroImageUrl || siteContent.homeFavorites[0]?.imageUrl || siteContent.catalogItems[0]?.imageUrl || "/assets/images/img-011.jpg";
const ogImageUrl = ogImagePath.startsWith("http") ? ogImagePath : `${baseUrl}${ogImagePath}`;

const heroTitle = siteContent.siteConfig.hero_titulo?.trim() || "La dulzura de lo artesanal";
const heroSubtitle =
  siteContent.siteConfig.hero_subtitulo?.trim() ||
  "Reposteria creativa en el corazon de Colima. Creamos momentos inolvidables con disenos unicos y sabores genuinos.";

const defaultCtaMessage =
  siteContent.siteConfig.cta_principal_mensaje?.trim() ||
  `Hola ${siteContent.businessName}, quiero hacer un pedido.`;
const favorites = (siteContent.homeFavorites.length > 0
  ? siteContent.homeFavorites
  : siteContent.catalogItems.slice(0, 4).map((item, idx) => ({
      id: `fav-fallback-${idx + 1}`,
      productId: item.id,
      nombre: item.nombre,
      descripcion: item.descripcion,
      precio: item.precio,
      imageUrl: item.imageUrl,
      orden: idx + 1,
      ctaTexto: siteContent.cta
    }))).slice(0, 4);

const favoriteCards = favorites.map((item) => {
  const message = (item.ctaPlantilla || `Hola ${siteContent.businessName}, quiero ordenar ${item.nombre}.`).replace(
    /\{\{\s*producto_nombre\s*\}\}/gi,
    item.nombre
  );
  return {
    ...item,
    href: buildWhatsAppLink(siteContent.whatsapp, message)
  };
});

const stepFallback = siteContent.howToOrderSteps.map((descripcion, index) => ({
  id: `paso-${index + 1}`,
  orden: index + 1,
  titulo: `Paso ${index + 1}`,
  descripcion,
  icono: ["menu_book", "chat", "event_available", "cake"][index] || "cake"
}));
const orderSteps = (siteContent.orderSteps.length > 0 ? siteContent.orderSteps : stepFallback).slice(0, 4);

const gallery = (siteContent.gallery.length > 0
  ? siteContent.gallery
  : siteContent.catalogItems.map((item) => item.imageUrl)
).slice(0, 6);

const testimonials = (siteContent.testimonials.length > 0
  ? siteContent.testimonials
  : [
      { text: "El pastel quedo hermoso y delicioso.", author: "Cliente frecuente" },
      { text: "Puntuales y atentos en todo momento.", author: "Cliente local" }
    ]
).slice(0, 3);

const whatsappFabHref = buildWhatsAppLink(siteContent.whatsapp, defaultCtaMessage);
---
<BaseLayout htmlClass="scroll-smooth" lang="es" bodyClass="bg-background font-body text-on-surface">
  <Fragment slot="head">
    <meta name="description" content={seoDescription} />
    <meta name="robots" content="index,follow" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
    <meta property="og:title" content={seoTitle} />
    <meta property="og:description" content={seoDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteContent.businessName} />
    <meta property="og:locale" content="es_MX" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seoTitle} />
    <meta name="twitter:description" content={seoDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <title>{seoTitle}</title>
    <script is:inline src="/assets/vendor/tailwindcss-cdn.js"></script>
    <link href="/assets/vendor/fonts-02.css" rel="stylesheet" />
    <link href="/assets/vendor/fonts-04.css" rel="stylesheet" />
    <script is:inline id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              "on-secondary-fixed": "#201a19",
              "primary-fixed-dim": "#efbc9b",
              "surface-container-high": "#e8e8e8",
              "inverse-surface": "#2f3131",
              "error-container": "#ffdad6",
              "on-secondary": "#ffffff",
              "secondary-container": "#e9ddda",
              "inverse-primary": "#efbc9b",
              "tertiary-container": "#a0c7d3",
              "on-tertiary-fixed-variant": "#254c56",
              "surface-bright": "#f9f9f9",
              secondary: "#655d5a",
              "on-primary-fixed": "#2f1502",
              "on-error-container": "#93000a",
              "on-surface-variant": "#50443d",
              "on-secondary-container": "#69615e",
              "surface-container-lowest": "#ffffff",
              "secondary-fixed-dim": "#cfc4c1",
              "on-background": "#1a1c1c",
              primary: "#7c563b",
              "inverse-on-surface": "#f1f1f1",
              "primary-fixed": "#ffdcc6",
              "surface-dim": "#dadada",
              "surface-container-highest": "#e2e2e2",
              tertiary: "#3e646e",
              "on-tertiary": "#ffffff",
              "surface-container": "#eeeeee",
              "on-tertiary-fixed": "#001f26",
              "primary-container": "#e8b695",
              "tertiary-fixed": "#c1e9f5",
              "surface-variant": "#e2e2e2",
              "on-error": "#ffffff",
              "tertiary-fixed-dim": "#a6cdd9",
              "surface-container-low": "#f3f3f3",
              "on-primary-container": "#6a462c",
              "surface-tint": "#7c563b",
              "on-surface": "#1a1c1c",
              error: "#ba1a1a",
              "on-primary": "#ffffff",
              "on-primary-fixed-variant": "#623f25",
              "secondary-fixed": "#ece0dd",
              "on-secondary-fixed-variant": "#4d4543",
              background: "#f9f9f9",
              "outline-variant": "#d4c3b9",
              outline: "#82746c",
              "on-tertiary-container": "#2e545e",
              surface: "#f9f9f9"
            },
            fontFamily: {
              headline: ["Epilogue"],
              body: ["Plus Jakarta Sans"],
              label: ["Plus Jakarta Sans"]
            },
            borderRadius: {
              DEFAULT: "1rem",
              lg: "2rem",
              xl: "3rem",
              full: "9999px"
            }
          }
        }
      }
    </script>
  </Fragment>

  <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[999] focus:bg-primary focus:text-white focus:px-4 focus:py-2 focus:rounded-full">Saltar al contenido</a>
  <Header />

  <main id="main-content">
    <section class="relative px-6 pt-12 pb-20 md:py-28 overflow-hidden">
      <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center gap-12">
        <div class="flex-1 text-center md:text-left z-10">
          <span class="inline-block py-1 px-4 rounded-full bg-secondary-container text-on-secondary-container text-sm font-semibold mb-6">Artesanal y creativo</span>
          <h1 class="font-headline text-5xl md:text-7xl font-black text-on-surface leading-[1.1] mb-6 tracking-tight">{heroTitle}</h1>
          <p class="text-on-surface-variant text-lg md:text-xl max-w-lg mb-10 leading-relaxed">{heroSubtitle}</p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start">
            <a class="hero-gradient text-white px-8 py-4 rounded-full font-bold text-lg shadow-lg hover:scale-105 transition-transform active:scale-95" href="catalogo.html">
              Ver catalogo
            </a>
            <a class="bg-surface-container-high text-on-surface px-8 py-4 rounded-full font-bold text-lg hover:bg-surface-container-highest transition-colors active:scale-95" href={whatsappFabHref} target="_blank" rel="noopener noreferrer">
              {siteContent.cta || "Ordenar por WhatsApp"}
            </a>
          </div>
        </div>
        <div class="flex-1 relative">
          <div class="relative w-full aspect-square max-w-md mx-auto">
            <div class="absolute inset-0 bg-primary-container/30 rounded-full blur-3xl -z-10 animate-pulse"></div>
            <img
              alt="Pastel artesanal Hadi Cakes"
              class="w-full h-full object-cover rounded-xl shadow-2xl rotate-3 hover:rotate-0 transition-transform duration-500"
              src={ogImagePath}
              decoding="async"
              loading="eager"
              fetchpriority="high"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 bg-surface-container-low rounded-t-xl">
      <div class="max-w-7xl mx-auto px-6">
        <div class="flex justify-between items-end mb-16">
          <div>
            <h2 class="font-headline text-3xl md:text-5xl font-extrabold text-on-surface mb-4">Favoritos de la casa</h2>
            <p class="text-on-surface-variant max-w-md">Creaciones destacadas que puedes actualizar desde Google Sheets sin tocar codigo.</p>
          </div>
          <a class="hidden md:flex items-center gap-2 text-primary font-bold hover:underline" href="catalogo.html">
            Explorar todo el menu
            <span class="material-symbols-outlined">arrow_forward</span>
          </a>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
          {favoriteCards.map((item) => (
            <div class="group bg-surface-container-lowest rounded-lg p-4 transition-all duration-300 hover:-translate-y-2">
              <div class="aspect-square rounded-DEFAULT overflow-hidden mb-6">
                <img alt={item.nombre} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" src={item.imageUrl} decoding="async" loading="lazy" />
              </div>
              <h3 class="font-headline text-xl font-bold mb-1">{item.nombre}</h3>
              <p class="text-primary font-bold text-lg mb-2">{formatPriceMxn(item.precio)}</p>
              {item.badge ? <p class="text-xs text-on-surface-variant mb-4">{item.badge}</p> : <div class="mb-4" />}
              <a class="w-full py-3 px-4 bg-primary-container/20 text-on-primary-container rounded-full font-bold flex items-center justify-center gap-2 group-hover:bg-primary-container transition-colors" href={item.href} target="_blank" rel="noopener noreferrer">
                <span class="material-symbols-outlined text-xl">chat</span>
                {item.ctaTexto || "Ordenar por WhatsApp"}
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="como-ordenar" class="py-24 px-6 max-w-7xl mx-auto">
      <h2 class="font-headline text-3xl md:text-5xl font-extrabold text-on-surface text-center mb-16">Como ordenar</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {orderSteps.map((step, index) => (
          <article class="bg-surface-container-low p-8 rounded-xl border border-outline-variant/30">
            <div class="w-14 h-14 rounded-full bg-primary-container flex items-center justify-center mb-5">
              <span class="material-symbols-outlined text-on-primary-container">{step.icono || "cake"}</span>
            </div>
            <p class="text-xs uppercase tracking-[0.2em] text-secondary mb-2">Paso {index + 1}</p>
            <h3 class="font-headline text-2xl font-bold mb-3 text-on-surface">{step.titulo}</h3>
            <p class="text-on-surface-variant leading-relaxed">{step.descripcion}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="py-24 bg-surface overflow-hidden">
      <div class="max-w-7xl mx-auto px-6 mb-12 flex justify-between items-center">
        <h2 class="font-headline text-3xl font-extrabold">Momentos {siteContent.businessName}</h2>
      </div>
      <div class="flex gap-6 px-6 no-scrollbar overflow-x-auto pb-8">
        {gallery.map((image, index) => (
          <img alt={`Galeria Hadi Cakes ${index + 1}`} class="w-80 h-96 object-cover rounded-lg flex-shrink-0 shadow-sm" src={image} decoding="async" loading="lazy" />
        ))}
      </div>
    </section>

    <section class="py-24 bg-surface-container-low">
      <div class="max-w-7xl mx-auto px-6">
        <h2 class="font-headline text-4xl font-extrabold mb-8">Lo que dicen nuestros clientes</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {testimonials.map((item) => (
            <article class="p-6 bg-surface-container-lowest rounded-lg shadow-sm">
              <p class="text-on-surface mb-4 italic">&quot;{item.text}&quot;</p>
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-primary-container/30 flex items-center justify-center text-primary font-bold">
                  {item.author.trim().charAt(0).toUpperCase() || "C"}
                </div>
                <span class="font-bold">{item.author}</span>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <BottomNav />

  <a class="fixed bottom-24 right-6 md:bottom-8 md:right-8 w-16 h-16 bg-[#25D366] text-white rounded-full flex items-center justify-center shadow-2xl hover:scale-110 transition-transform z-40" href={whatsappFabHref} target="_blank" rel="noopener noreferrer" aria-label="Abrir WhatsApp">
    <span class="material-symbols-outlined text-4xl" style="font-variation-settings: 'FILL' 1;">chat</span>
  </a>
</BaseLayout>
