---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import BottomNav from "../components/BottomNav.astro";
import {
  baseUrlFromConfig,
  buildWhatsAppLink,
  formatPriceMxn,
  siteContent
} from "../lib/site-content";
import "../styles/pages/catalogo.css";

const baseUrl = baseUrlFromConfig();
const canonicalUrl = `${baseUrl}/catalogo.html`;
const seoTitle = siteContent.siteConfig.seo_titulo_catalogo?.trim() || `Catalogo | ${siteContent.businessName}`;
const seoDescription =
  siteContent.siteConfig.seo_descripcion_catalogo?.trim() ||
  `Catalogo ${siteContent.businessName}: pasteles, cupcakes y productos artesanales disponibles en Colima.`;
const ogImagePath = siteContent.catalogItems[0]?.imageUrl || siteContent.heroImageUrl || "/assets/catalog/producto_01.jpg";
const ogImageUrl = ogImagePath.startsWith("http") ? ogImagePath : `${baseUrl}${ogImagePath}`;

const products = siteContent.catalogItems;
const categories = ["Todos", ...new Set(products.map((item) => item.categoria || "especialidades"))];
const ctaMessageDefault = siteContent.siteConfig.cta_catalogo_mensaje?.trim() ||
  `Hola ${siteContent.businessName}, quiero cotizar un producto del catalogo.`;

const productCards = products.map((item) => {
  const message = `Hola ${siteContent.businessName}, quiero ordenar ${item.nombre}.`;
  return {
    ...item,
    waHref: buildWhatsAppLink(siteContent.whatsapp, message)
  };
});

const customOrderHref = buildWhatsAppLink(
  siteContent.whatsapp,
  siteContent.customOrder.ctaMessage || ctaMessageDefault
);
---
<BaseLayout htmlClass="light" lang="es" bodyClass="bg-background font-body text-on-surface">
  <Fragment slot="head">
    <meta name="description" content={seoDescription} />
    <meta name="robots" content="index,follow" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
    <meta property="og:title" content={seoTitle} />
    <meta property="og:description" content={seoDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteContent.businessName} />
    <meta property="og:locale" content="es_MX" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seoTitle} />
    <meta name="twitter:description" content={seoDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <title>{seoTitle}</title>
    <link href="/assets/vendor/fonts-02.css" rel="stylesheet" />
    <link href="/assets/vendor/fonts-04.css" rel="stylesheet" />
    <script is:inline src="/assets/vendor/tailwindcss-cdn.js"></script>
    <script is:inline id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              "on-secondary-fixed": "#201a19",
              "primary-fixed-dim": "#efbc9b",
              "surface-container-high": "#e8e8e8",
              "inverse-surface": "#2f3131",
              "error-container": "#ffdad6",
              "on-secondary": "#ffffff",
              "secondary-container": "#e9ddda",
              "inverse-primary": "#efbc9b",
              "tertiary-container": "#a0c7d3",
              "on-tertiary-fixed-variant": "#254c56",
              "surface-bright": "#f9f9f9",
              secondary: "#655d5a",
              "on-primary-fixed": "#2f1502",
              "on-error-container": "#93000a",
              "on-surface-variant": "#50443d",
              "on-secondary-container": "#69615e",
              "surface-container-lowest": "#ffffff",
              "secondary-fixed-dim": "#cfc4c1",
              "on-background": "#1a1c1c",
              primary: "#7c563b",
              "inverse-on-surface": "#f1f1f1",
              "primary-fixed": "#ffdcc6",
              "surface-dim": "#dadada",
              "surface-container-highest": "#e2e2e2",
              tertiary: "#3e646e",
              "on-tertiary": "#ffffff",
              "surface-container": "#eeeeee",
              "on-tertiary-fixed": "#001f26",
              "primary-container": "#e8b695",
              "tertiary-fixed": "#c1e9f5",
              "surface-variant": "#e2e2e2",
              "on-error": "#ffffff",
              "tertiary-fixed-dim": "#a6cdd9",
              "surface-container-low": "#f3f3f3",
              "on-primary-container": "#6a462c",
              "surface-tint": "#7c563b",
              "on-surface": "#1a1c1c",
              error: "#ba1a1a",
              "on-primary": "#ffffff",
              "on-primary-fixed-variant": "#623f25",
              "secondary-fixed": "#ece0dd",
              "on-secondary-fixed-variant": "#4d4543",
              background: "#f9f9f9",
              "outline-variant": "#d4c3b9",
              outline: "#82746c",
              "on-tertiary-container": "#2e545e",
              surface: "#f9f9f9"
            },
            fontFamily: {
              headline: ["Epilogue"],
              body: ["Plus Jakarta Sans"],
              label: ["Plus Jakarta Sans"]
            },
            borderRadius: {
              DEFAULT: "1rem",
              lg: "2rem",
              xl: "3rem",
              full: "9999px"
            }
          }
        }
      }
    </script>
  </Fragment>

  <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[999] focus:bg-primary focus:text-white focus:px-4 focus:py-2 focus:rounded-full">Saltar al contenido</a>
  <Header />

  <main id="main-content" class="max-w-7xl mx-auto px-6 pt-12 pb-32">
    <section class="mb-16 text-center md:text-left">
      <h1 class="font-headline text-5xl md:text-7xl font-black text-on-surface tracking-tighter mb-6">Nuestro catalogo</h1>
      <p class="text-on-surface-variant text-lg md:text-xl max-w-2xl mb-10 leading-relaxed">
        Seleccion actualizable desde Sheets: cada producto puede editarse en precio, descripcion, imagen y orden sin cambios de codigo.
      </p>

      <div class="flex flex-col gap-8">
        <div class="relative max-w-xl group">
          <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline">search</span>
          <input class="w-full bg-surface-container-high border-none rounded-full py-4 pl-12 pr-6 focus:ring-2 focus:ring-primary/20 font-medium text-on-surface placeholder:text-outline" placeholder="Busqueda visual (modo estatico)" type="text" disabled />
        </div>

        <div class="flex flex-wrap gap-3 overflow-x-auto pb-2 scrollbar-hide">
          {categories.map((category, idx) => (
            <span class:list={["px-6 py-2 rounded-full font-semibold whitespace-nowrap", idx === 0 ? "bg-primary text-on-primary" : "bg-secondary-container text-on-secondary-container"]}>{category}</span>
          ))}
        </div>
      </div>
    </section>

    <section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-16">
      {productCards.map((item, index) => (
        <article class="group">
          <div class="relative aspect-square rounded-xl overflow-hidden bg-surface-container mb-6 shadow-sm transition-transform duration-500 group-hover:-translate-y-2">
            <img alt={item.nombre} class="w-full h-full object-cover" src={item.imageUrl} decoding="async" loading={index < 3 ? "eager" : "lazy"} fetchpriority={index < 3 ? "high" : undefined} />
            <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          </div>

          <div class="flex justify-between items-start gap-4">
            <div>
              <h3 class="font-headline text-2xl font-bold text-on-surface mb-1">{item.nombre}</h3>
              <p class="text-primary font-bold text-xl">{formatPriceMxn(item.precio)}{item.porciones ? ` / ${item.porciones} porciones` : ""}</p>
              {item.descripcion ? <p class="text-sm text-on-surface-variant mt-2">{item.descripcion}</p> : null}
            </div>
            <a class="bg-primary-container text-on-primary-container p-3 rounded-full hover:scale-110 active:scale-90 transition-all flex items-center justify-center" href={item.waHref} target="_blank" rel="noopener noreferrer" aria-label={`Ordenar ${item.nombre}`}>
              <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">shopping_cart</span>
            </a>
          </div>
        </article>
      ))}
    </section>

    <section class="mt-24 bg-primary-container/30 rounded-xl p-8 md:p-16 flex flex-col md:flex-row items-center gap-12 relative overflow-hidden">
      <div class="absolute -right-20 -top-20 w-64 h-64 bg-[#E8B695] rounded-full opacity-20 blur-3xl"></div>
      <div class="absolute -left-20 -bottom-20 w-64 h-64 bg-[#7C563B] rounded-full opacity-10 blur-3xl"></div>

      <div class="md:w-3/5 z-10">
        <h2 class="font-headline text-4xl md:text-5xl font-black text-primary mb-6">{siteContent.customOrder.title}</h2>
        <p class="text-on-primary-container text-lg md:text-xl mb-10 leading-relaxed font-medium">{siteContent.customOrder.description}</p>
        <a class="bg-primary text-on-primary px-8 py-4 rounded-full font-bold text-lg hover:scale-105 active:scale-95 transition-all shadow-lg" href={customOrderHref} target="_blank" rel="noopener noreferrer">
          {siteContent.customOrder.ctaLabel}
        </a>
      </div>

      <div class="md:w-2/5 relative group">
        <div class="aspect-square rounded-lg rotate-3 overflow-hidden shadow-2xl transition-transform group-hover:rotate-0">
          <img alt="Diseno personalizado" class="w-full h-full object-cover" src={siteContent.heroImageUrl || "/assets/catalog/producto_07.jpg"} decoding="async" loading="lazy" />
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <BottomNav />
</BaseLayout>
