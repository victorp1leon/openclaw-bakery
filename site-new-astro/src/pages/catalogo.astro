---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BottomNav from '../components/BottomNav.astro';
import '../styles/pages/catalogo.css';
---
<BaseLayout htmlClass="light" lang="es" bodyClass="bg-background font-body text-on-surface">
  <Fragment slot="head">
    <!-- SEO Pack2 Start -->
    <meta name="description" content="Catalogo Hadi Cakes: pasteles, cupcakes y galletas artesanales disponibles en Colima con pedido rapido por WhatsApp."/>
    <meta name="robots" content="index,follow"/>
    <link rel="canonical" href="https://hadicakes.local/catalogo.html"/>
    <link rel="icon" type="image/svg+xml" href="assets/favicon.svg"/>
    <meta property="og:title" content="Catálogo | Hadi Cakes - Repostería Creativa"/>
    <meta property="og:description" content="Catalogo Hadi Cakes: pasteles, cupcakes y galletas artesanales disponibles en Colima con pedido rapido por WhatsApp."/>
    <meta property="og:type" content="website"/>
    <meta property="og:site_name" content="Hadi Cakes"/>
    <meta property="og:locale" content="es_MX"/>
    <meta property="og:url" content="https://hadicakes.local/catalogo.html"/>
    <meta property="og:image" content="https://hadicakes.local/assets/images/img-031.jpg"/>
    <meta name="twitter:card" content="summary_large_image"/>
    <meta name="twitter:title" content="Catálogo | Hadi Cakes - Repostería Creativa"/>
    <meta name="twitter:description" content="Catalogo Hadi Cakes: pasteles, cupcakes y galletas artesanales disponibles en Colima con pedido rapido por WhatsApp."/>
    <meta name="twitter:image" content="https://hadicakes.local/assets/images/img-031.jpg"/>
    <!-- SEO Pack2 End -->
    <title>Catálogo | Hadi Cakes - Repostería Creativa</title>
    <!-- Fonts -->
    <link href="/assets/vendor/fonts-02.css" rel="stylesheet"/>
    <!-- Material Symbols -->
    <link href="/assets/vendor/fonts-04.css" rel="stylesheet"/>
    <!-- Tailwind CSS -->
    <script is:inline src="/assets/vendor/tailwindcss-cdn.js"></script>
    <script is:inline id="tailwind-config">
          tailwind.config = {
            darkMode: "class",
            theme: {
              extend: {
                colors: {
                  "on-secondary-fixed": "#201a19",
                  "primary-fixed-dim": "#efbc9b",
                  "surface-container-high": "#e8e8e8",
                  "inverse-surface": "#2f3131",
                  "error-container": "#ffdad6",
                  "on-secondary": "#ffffff",
                  "secondary-container": "#e9ddda",
                  "inverse-primary": "#efbc9b",
                  "tertiary-container": "#a0c7d3",
                  "on-tertiary-fixed-variant": "#254c56",
                  "surface-bright": "#f9f9f9",
                  "secondary": "#655d5a",
                  "on-primary-fixed": "#2f1502",
                  "on-error-container": "#93000a",
                  "on-surface-variant": "#50443d",
                  "on-secondary-container": "#69615e",
                  "surface-container-lowest": "#ffffff",
                  "secondary-fixed-dim": "#cfc4c1",
                  "on-background": "#1a1c1c",
                  "primary": "#7c563b",
                  "inverse-on-surface": "#f1f1f1",
                  "primary-fixed": "#ffdcc6",
                  "surface-dim": "#dadada",
                  "surface-container-highest": "#e2e2e2",
                  "tertiary": "#3e646e",
                  "on-tertiary": "#ffffff",
                  "surface-container": "#eeeeee",
                  "on-tertiary-fixed": "#001f26",
                  "primary-container": "#e8b695",
                  "tertiary-fixed": "#c1e9f5",
                  "surface-variant": "#e2e2e2",
                  "on-error": "#ffffff",
                  "tertiary-fixed-dim": "#a6cdd9",
                  "surface-container-low": "#f3f3f3",
                  "on-primary-container": "#6a462c",
                  "surface-tint": "#7c563b",
                  "on-surface": "#1a1c1c",
                  "error": "#ba1a1a",
                  "on-primary": "#ffffff",
                  "on-primary-fixed-variant": "#623f25",
                  "secondary-fixed": "#ece0dd",
                  "on-secondary-fixed-variant": "#4d4543",
                  "background": "#f9f9f9",
                  "outline-variant": "#d4c3b9",
                  "outline": "#82746c",
                  "on-tertiary-container": "#2e545e",
                  "surface": "#f9f9f9"
                },
                fontFamily: {
                  "headline": ["Epilogue"],
                  "body": ["Plus Jakarta Sans"],
                  "label": ["Plus Jakarta Sans"]
                },
                borderRadius: {"DEFAULT": "1rem", "lg": "2rem", "xl": "3rem", "full": "9999px"},
              },
            },
          }
        </script>
  </Fragment>
  <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[999] focus:bg-primary focus:text-white focus:px-4 focus:py-2 focus:rounded-full">Saltar al contenido</a>
  <Header />
  <main id="main-content" class="max-w-7xl mx-auto px-6 pt-12 pb-32">
  <!-- Hero Search Section -->
  <section class="mb-16 text-center md:text-left">
  <h1 class="font-headline text-5xl md:text-7xl font-black text-on-surface tracking-tighter mb-6">Nuestro Catálogo</h1>
  <p class="text-on-surface-variant text-lg md:text-xl max-w-2xl mb-10 leading-relaxed">
                  Descubre creaciones artesanales hechas con amor y los mejores ingredientes. Un bocado de felicidad en cada diseño.
              </p>
  <!-- Search & Filters -->
  <div class="flex flex-col gap-8">
  <div class="relative max-w-xl group">
  <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline">search</span>
  <input class="w-full bg-surface-container-high border-none rounded-full py-4 pl-12 pr-6 focus:ring-2 focus:ring-primary/20 font-medium text-on-surface placeholder:text-outline" placeholder="¿Qué delicia buscas hoy?" type="text"/>
  </div>
  <div class="flex flex-wrap gap-3 overflow-x-auto pb-2 scrollbar-hide">
  <button class="px-6 py-2 bg-primary text-on-primary rounded-full font-semibold whitespace-nowrap">Todos</button>
  <button class="px-6 py-2 bg-secondary-container text-on-secondary-container rounded-full font-semibold whitespace-nowrap hover:bg-primary-container transition-colors">Pasteles</button>
  <button class="px-6 py-2 bg-secondary-container text-on-secondary-container rounded-full font-semibold whitespace-nowrap hover:bg-primary-container transition-colors">Cupcakes</button>
  <button class="px-6 py-2 bg-secondary-container text-on-secondary-container rounded-full font-semibold whitespace-nowrap hover:bg-primary-container transition-colors">Galletas</button>
  <button class="px-6 py-2 bg-secondary-container text-on-secondary-container rounded-full font-semibold whitespace-nowrap hover:bg-primary-container transition-colors">Personalizados</button>
  </div>
  </div>
  </section>
  <!-- Product Grid -->
  <section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-16">
  <!-- Product 1 -->
  <div class="group">
  <div class="relative aspect-square rounded-xl overflow-hidden bg-surface-container mb-6 shadow-sm transition-transform duration-500 group-hover:-translate-y-2">
  <img alt="exquisite three-tier chocolate cake with smooth chocolate ganache and gold leaf accents on a white marble pedestal" class="w-full h-full object-cover" data-alt="exquisite three-tier chocolate cake with smooth chocolate ganache and gold leaf accents on a white marble pedestal" src="assets/images/img-031.jpg" decoding="async" loading="eager" fetchpriority="high">
  <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
  </div>
  <div class="flex justify-between items-start">
  <div>
  <h3 class="font-headline text-2xl font-bold text-on-surface mb-1">Chocolate Royal</h3>
  <p class="text-primary font-bold text-xl">$850 MXN</p>
  </div>
  <a class="bg-primary-container text-on-primary-container p-3 rounded-full hover:scale-110 active:scale-90 transition-all flex items-center justify-center" href="producto-detalle.html">
  <span class="material-symbols-outlined" data-weight="fill" style="font-variation-settings: 'FILL' 1;">shopping_cart</span>
  </a>
  </div>
  </div>
  <!-- Product 2 -->
  <div class="group">
  <div class="relative aspect-square rounded-xl overflow-hidden bg-surface-container mb-6 shadow-sm transition-transform duration-500 group-hover:-translate-y-2">
  <img alt="delicate vanilla cupcakes with pastel pink buttercream frosting and edible flowers in a bright sunny kitchen" class="w-full h-full object-cover" data-alt="delicate vanilla cupcakes with pastel pink buttercream frosting and edible flowers in a bright sunny kitchen" src="assets/images/img-007.jpg" decoding="async" loading="lazy">
  </div>
  <div class="flex justify-between items-start">
  <div>
  <h3 class="font-headline text-2xl font-bold text-on-surface mb-1">Cupcakes Jardín</h3>
  <p class="text-primary font-bold text-xl">$320 MXN / 6 pzas</p>
  </div>
  <a class="bg-primary-container text-on-primary-container p-3 rounded-full hover:scale-110 active:scale-90 transition-all flex items-center justify-center" href="producto-detalle.html">
  <span class="material-symbols-outlined" data-weight="fill" style="font-variation-settings: 'FILL' 1;">shopping_cart</span>
  </a>
  </div>
  </div>
  <!-- Product 3 -->
  <div class="group">
  <div class="relative aspect-square rounded-xl overflow-hidden bg-surface-container mb-6 shadow-sm transition-transform duration-500 group-hover:-translate-y-2">
  <img alt="assorted artisanal butter cookies with intricate royal icing designs and pastel colors on a rustic wooden plate" class="w-full h-full object-cover" data-alt="assorted artisanal butter cookies with intricate royal icing designs and pastel colors on a rustic wooden plate" src="assets/images/img-009.jpg" decoding="async" loading="lazy">
  </div>
  <div class="flex justify-between items-start">
  <div>
  <h3 class="font-headline text-2xl font-bold text-on-surface mb-1">Galletas Deco</h3>
  <p class="text-primary font-bold text-xl">$450 MXN / docena</p>
  </div>
  <a class="bg-primary-container text-on-primary-container p-3 rounded-full hover:scale-110 active:scale-90 transition-all flex items-center justify-center" href="producto-detalle.html">
  <span class="material-symbols-outlined" data-weight="fill" style="font-variation-settings: 'FILL' 1;">shopping_cart</span>
  </a>
  </div>
  </div>
  <!-- Product 4 -->
  <div class="group">
  <div class="relative aspect-square rounded-xl overflow-hidden bg-surface-container mb-6 shadow-sm transition-transform duration-500 group-hover:-translate-y-2">
  <img alt="vibrant rainbow sprinkle birthday cake with white frosting and colorful candles in a festive celebration setting" class="w-full h-full object-cover" data-alt="vibrant rainbow sprinkle birthday cake with white frosting and colorful candles in a festive celebration setting" src="assets/images/img-001.jpg" decoding="async" loading="lazy">
  </div>
  <div class="flex justify-between items-start">
  <div>
  <h3 class="font-headline text-2xl font-bold text-on-surface mb-1">Fiesta de Colores</h3>
  <p class="text-primary font-bold text-xl">$680 MXN</p>
  </div>
  <a class="bg-primary-container text-on-primary-container p-3 rounded-full hover:scale-110 active:scale-90 transition-all flex items-center justify-center" href="producto-detalle.html">
  <span class="material-symbols-outlined" data-weight="fill" style="font-variation-settings: 'FILL' 1;">shopping_cart</span>
  </a>
  </div>
  </div>
  <!-- Product 5 -->
  <div class="group">
  <div class="relative aspect-square rounded-xl overflow-hidden bg-surface-container mb-6 shadow-sm transition-transform duration-500 group-hover:-translate-y-2">
  <img alt="minimalist strawberry shortcake with fresh organic berries and whipped cream on a clean ceramic plate" class="w-full h-full object-cover" data-alt="minimalist strawberry shortcake with fresh organic berries and whipped cream on a clean ceramic plate" src="assets/images/img-028.jpg" decoding="async" loading="lazy">
  </div>
  <div class="flex justify-between items-start">
  <div>
  <h3 class="font-headline text-2xl font-bold text-on-surface mb-1">Nube de Fresa</h3>
  <p class="text-primary font-bold text-xl">$720 MXN</p>
  </div>
  <a class="bg-primary-container text-on-primary-container p-3 rounded-full hover:scale-110 active:scale-90 transition-all flex items-center justify-center" href="producto-detalle.html">
  <span class="material-symbols-outlined" data-weight="fill" style="font-variation-settings: 'FILL' 1;">shopping_cart</span>
  </a>
  </div>
  </div>
  <!-- Product 6 -->
  <div class="group">
  <div class="relative aspect-square rounded-xl overflow-hidden bg-surface-container mb-6 shadow-sm transition-transform duration-500 group-hover:-translate-y-2">
  <img alt="velvety red velvet cake with thick cream cheese frosting and deep red sponge layers visible in the cut" class="w-full h-full object-cover" data-alt="velvety red velvet cake with thick cream cheese frosting and deep red sponge layers visible in the cut" src="assets/images/img-005.jpg" decoding="async" loading="lazy">
  </div>
  <div class="flex justify-between items-start">
  <div>
  <h3 class="font-headline text-2xl font-bold text-on-surface mb-1">Red Velvet Dream</h3>
  <p class="text-primary font-bold text-xl">$790 MXN</p>
  </div>
  <a class="bg-primary-container text-on-primary-container p-3 rounded-full hover:scale-110 active:scale-90 transition-all flex items-center justify-center" href="producto-detalle.html">
  <span class="material-symbols-outlined" data-weight="fill" style="font-variation-settings: 'FILL' 1;">shopping_cart</span>
  </a>
  </div>
  </div>
  </section>
  <!-- CTA Section: Special Design -->
  <section class="mt-24 bg-primary-container/30 rounded-xl p-8 md:p-16 flex flex-col md:flex-row items-center gap-12 relative overflow-hidden">
  <div class="absolute -right-20 -top-20 w-64 h-64 bg-[#E8B695] rounded-full opacity-20 blur-3xl"></div>
  <div class="absolute -left-20 -bottom-20 w-64 h-64 bg-[#7C563B] rounded-full opacity-10 blur-3xl"></div>
  <div class="md:w-3/5 z-10">
  <h2 class="font-headline text-4xl md:text-5xl font-black text-primary mb-6">¿No encuentras lo que buscas?</h2>
  <p class="text-on-primary-container text-lg md:text-xl mb-10 leading-relaxed font-medium">
                      Hacemos realidad el pastel de tus sueños. Cuéntanos tu idea, temática o sabor favorito y crearemos algo único para tu evento.
                  </p>
  <a class="bg-primary text-on-primary px-8 py-4 rounded-full font-bold text-lg hover:scale-105 active:scale-95 transition-all shadow-lg" href="pasteles-personalizados.html#cotizacion">
                      Solicitar diseño especial
                  </a>
  </div>
  <div class="md:w-2/5 relative group">
  <div class="aspect-square rounded-lg rotate-3 overflow-hidden shadow-2xl transition-transform group-hover:rotate-0">
  <img alt="pastry chef hands intricately decorating a designer cake with fine tools and edible gold dust in a professional atelier" class="w-full h-full object-cover" data-alt="pastry chef hands intricately decorating a designer cake with fine tools and edible gold dust in a professional atelier" src="assets/images/img-020.jpg" decoding="async" loading="lazy">
  </div>
  <div class="absolute -bottom-6 -right-6 bg-white p-4 rounded-lg shadow-xl hidden md:block animate-bounce">
  <span class="material-symbols-outlined text-primary text-4xl" style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
  </div>
  </div>
  </section>
  </main>
  <Footer />
  <BottomNav />
</BaseLayout>
